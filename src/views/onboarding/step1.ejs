<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrfToken %>">
    <title><%= title %> · Todo</title>
    <%- include('../partials/theme-bootstrap') %>
    <%- viteAssets() %>
  </head>
  <body data-theme="<%= currentUser?.theme_preference || 'system' %>" data-default-priority="<%= currentUser?.default_priority || 'medium' %>" data-default-view="<%= currentUser?.default_view || 'list' %>" class="bg-md-primary-container text-md-on-primary-container">
    <main role="main" data-onboarding-page class="animate-onboarding-enter relative flex min-h-screen flex-col items-center justify-center bg-md-primary-container px-8 text-center">
      <a href="/onboarding/step-3" data-onboarding-link class="absolute right-4 top-4 text-md-label-large text-md-on-primary-container underline">Skip</a>
      <%- include('./partials/progress-dots', { currentStep }) %>
      <div class="mt-10 flex h-28 w-28 items-center justify-center rounded-full bg-md-primary text-md-on-primary shadow-lg">
        <svg viewBox="0 0 48 48" class="h-14 w-14 fill-none stroke-current" stroke-width="3">
          <circle cx="24" cy="24" r="19" opacity="0.28"></circle>
          <path d="M15 24.5l6 6L33.5 18" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </div>
      <p class="mt-10 text-md-display-small text-md-on-primary-container">Todo Flow</p>
      <p class="mt-4 text-md-body-large text-md-on-primary-container/90">A focused mobile task system built to get you from capture to completion fast.</p>
      <a href="/onboarding/step-2" data-onboarding-link class="mt-10 inline-flex w-full max-w-sm items-center justify-center rounded-md-full bg-md-primary py-4 text-md-label-large text-md-on-primary">Get started</a>
    </main>
  </body>
</html>
