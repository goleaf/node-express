<%
  const path = currentPath || '';
  const navItems = [
    {
      key: 'home',
      href: '/dashboard',
      label: 'Home',
      active: path === '/' || path.startsWith('/dashboard'),
      icon: 'home',
    },
    {
      key: 'search',
      href: '/search',
      label: 'Search',
      active: path.startsWith('/search'),
      icon: 'search',
    },
    {
      key: 'categories',
      href: '/categories',
      label: 'Categories',
      active: path.startsWith('/categories') || path.startsWith('/tags'),
      icon: 'grid',
    },
    {
      key: 'profile',
      href: '/profile',
      label: 'Profile',
      active: path.startsWith('/profile'),
      icon: 'profile',
    },
  ];
%>
<nav data-bottom-nav role="navigation" aria-label="Main navigation" class="fixed bottom-0 left-0 right-0 z-50 border-t border-md-outline-variant bg-md-surface pb-[env(safe-area-inset-bottom)]">
  <div class="flex items-center">
    <% navItems.forEach((item) => { %>
      <a href="<%= item.href %>" data-bottom-nav-item tabindex="<%= item.active ? '0' : '-1' %>" <% if (item.active) { %>aria-current="page"<% } %> class="touch-target flex flex-1 flex-col items-center py-2">
        <span class="<%= item.active ? 'rounded-md-full bg-md-secondary-container px-4 py-1 text-md-on-secondary-container' : 'px-4 py-1 text-md-on-surface-variant' %>">
          <% if (item.icon === 'home') { %>
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="1.8">
              <path d="M4 10.5L12 4l8 6.5" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M6.5 10v9h11v-9" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          <% } %>
          <% if (item.icon === 'search') { %>
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="1.8">
              <path d="M11 5a6 6 0 1 1 0 12 6 6 0 0 1 0-12z" />
              <path d="M20 20l-4.2-4.2" stroke-linecap="round" />
            </svg>
          <% } %>
          <% if (item.icon === 'grid') { %>
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="1.8">
              <path d="M5 5h5v5H5zM14 5h5v5h-5zM5 14h5v5H5zM14 14h5v5h-5z" stroke-linejoin="round" />
            </svg>
          <% } %>
          <% if (item.icon === 'profile') { %>
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="1.8">
              <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" />
              <path d="M4 20a8 8 0 0 1 16 0" stroke-linecap="round" />
            </svg>
          <% } %>
        </span>
        <span class="<%= item.active ? 'text-md-label-medium text-md-on-surface' : 'text-md-label-medium text-md-on-surface-variant' %>">
          <%= item.label %>
        </span>
      </a>
    <% }) %>
  </div>
</nav>
