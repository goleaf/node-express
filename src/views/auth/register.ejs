<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrfToken %>">
    <title><%= title %> · Todo</title>
    <%- include('../partials/theme-bootstrap') %>
    <%- viteAssets() %>
  </head>
  <body data-theme="<%= currentUser?.theme_preference || 'system' %>" data-default-priority="<%= currentUser?.default_priority || 'medium' %>" data-default-view="<%= currentUser?.default_view || 'list' %>" class="bg-md-background text-md-on-background">
    <main class="mx-auto flex min-h-screen w-full max-w-md items-center px-md-4 py-md-6">
      <section class="w-full rounded-md-extra-large bg-md-surface p-md-6 shadow-sm ring-1 ring-md-outline-variant/60">
        <p class="text-md-label-large uppercase tracking-[0.12em] text-md-primary">New Account</p>
        <h1 class="mt-md-3 text-md-headline-small">Create your account</h1>
        <p class="mt-md-2 text-md-body-medium text-md-on-surface-variant">Set up a personal workspace for tasks, categories, and reminders.</p>

        <% if (pageError) { %>
          <div class="mt-md-4 rounded-md-large bg-md-error-container px-md-4 py-md-3 text-md-body-medium text-md-on-error-container">
            <%= pageError %>
          </div>
        <% } %>

        <form class="mt-md-5 space-y-md-4" method="post" action="/auth/register">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <label class="block">
            <span class="mb-md-2 block text-md-label-large text-md-on-surface">Name</span>
            <input class="w-full rounded-md-large border border-md-outline-variant bg-md-background px-md-4 py-md-3 text-md-body-large text-md-on-background outline-none" type="text" name="name" value="<%= form.name %>" autocomplete="name" required>
          </label>
          <label class="block">
            <span class="mb-md-2 block text-md-label-large text-md-on-surface">Email</span>
            <input class="w-full rounded-md-large border border-md-outline-variant bg-md-background px-md-4 py-md-3 text-md-body-large text-md-on-background outline-none" type="email" name="email" value="<%= form.email %>" autocomplete="email" required>
          </label>
          <label class="block">
            <span class="mb-md-2 block text-md-label-large text-md-on-surface">Password</span>
            <input class="w-full rounded-md-large border border-md-outline-variant bg-md-background px-md-4 py-md-3 text-md-body-large text-md-on-background outline-none" type="password" name="password" autocomplete="new-password" required>
          </label>
          <label class="block">
            <span class="mb-md-2 block text-md-label-large text-md-on-surface">Confirm password</span>
            <input class="w-full rounded-md-large border border-md-outline-variant bg-md-background px-md-4 py-md-3 text-md-body-large text-md-on-background outline-none" type="password" name="password_confirmation" autocomplete="new-password" required>
          </label>
          <button class="w-full rounded-md-full bg-md-primary px-md-4 py-md-3 text-md-label-large text-md-on-primary" type="submit">
            Create account
          </button>
        </form>

        <div class="mt-md-5 text-md-body-medium text-md-on-surface-variant">
          Already have an account?
          <a class="text-md-primary" href="/auth/login">Log in</a>
        </div>
      </section>
    </main>
  </body>
</html>
