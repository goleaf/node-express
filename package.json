{
  "name": "node-express-todo-app",
  "version": "1.0.0",
  "description": "A tiny Node.js + Express todo application",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "concurrently \"nodemon --watch src --ext js,ejs src/app.js\" \"vite --host 0.0.0.0 --port 5173\"",
    "build": "vite build",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "nodemon": "^3.1.9",
    "postcss": "^8.5.3",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5"
  }
}
